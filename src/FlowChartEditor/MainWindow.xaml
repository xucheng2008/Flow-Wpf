<Window x:Class="FlowChartEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FlowChartEditor"
        xmlns:controls="clr-namespace:FlowChartEditor.Controls"
        mc:Ignorable="d"
        Title="Flow Chart Editor" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="{Binding NewCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open" Command="{Binding OpenCommand}" InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Delete" Command="{Binding DeleteCommand}" InputGestureText="Del"/>
                <MenuItem Header="Cu_t" Command="{Binding CutCommand}" InputGestureText="Ctrl+X"/>
                <MenuItem Header="_Copy" Command="{Binding CopyCommand}" InputGestureText="Ctrl+C"/>
                <MenuItem Header="_Paste" Command="{Binding PasteCommand}" InputGestureText="Ctrl+V"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Zoom _In" Command="{Binding ZoomInCommand}" InputGestureText="Ctrl++"/>
                <MenuItem Header="Zoom _Out" Command="{Binding ZoomOutCommand}" InputGestureText="Ctrl+-"/>
                <MenuItem Header="_Reset Zoom" Command="{Binding ResetZoomCommand}" InputGestureText="Ctrl+0"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="Rectangle" 
                        Command="{Binding AddRectangleCommand}"
                        ToolTip="Add Rectangle Node"/>
                <Button Content="Diamond" 
                        Command="{Binding AddDiamondCommand}"
                        ToolTip="Add Diamond Node"/>
                <Button Content="Circle" 
                        Command="{Binding AddCircleCommand}"
                        ToolTip="Add Circle Node"/>
                <Button Content="Rounded Rectangle" 
                        Command="{Binding AddRoundedRectangleCommand}"
                        ToolTip="Add Rounded Rectangle Node"/>
                <Separator/>
                <Button Content="Delete" 
                        Command="{Binding DeleteCommand}"
                        ToolTip="Delete Selected Node"/>
                <Separator/>
                <Button Content="+" 
                        Command="{Binding ZoomInCommand}"
                        ToolTip="Zoom In"/>
                <Button Content="-" 
                        Command="{Binding ZoomOutCommand}"
                        ToolTip="Zoom Out"/>
                <Button Content="100%" 
                        Command="{Binding ResetZoomCommand}"
                        ToolTip="Reset Zoom"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Main Canvas Area -->
        <Grid DockPanel.Dock="Top">
            <controls:ZoomBorder x:Name="zoomBorder">
                <controls:FlowChartCanvas x:Name="flowChartCanvas"
                    Nodes="{Binding Nodes}"
                    Connections="{Binding Connections}"/>
            </controls:ZoomBorder>
        </Grid>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding ElementName=zoomBorder, Path=ZoomFactor, StringFormat='Zoom: {0:P0}'}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding SelectedNodes.Count, StringFormat='Selected: {0}'}"/>
            </StatusBarItem>
        </StatusBar>

    </DockPanel>
</Window>