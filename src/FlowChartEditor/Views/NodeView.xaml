<UserControl x:Class="FlowChartEditor.Views.NodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:FlowChartEditor.Converters"
             Width="{Binding Width}"
             Height="{Binding Height}">
    
    <UserControl.Resources>
        <converters:NodeTypeToShapeConverter x:Key="NodeTypeToShapeConverter"/>
        <converters:ConditionToVisibilityConverter x:Key="ConditionToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Grid>
        <!-- 节点形状 -->
        <Path x:Name="NodeShape"
              Data="{Binding Type, Converter={StaticResource NodeTypeToShapeConverter}}"
              Fill="{Binding FillColor}"
              Stroke="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"
              StrokeThickness="2"
              Stretch="Fill"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"/>
        
        <!-- 选中状态边框 -->
        <Path x:Name="SelectedBorder"
              Data="{Binding Type, Converter={StaticResource NodeTypeToShapeConverter}}"
              Fill="Transparent"
              Stroke="#FF4081"
              StrokeThickness="3"
              Stretch="Fill"
              Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"/>
        
        <!-- 节点标签 -->
        <TextBlock Text="{Binding Label}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   FontSize="12"
                   FontFamily="Arial"
                   Foreground="#333333"
                   TextAlignment="Center"
                   Margin="5"/>
        
        <!-- 条件文本（仅菱形节点显示） -->
        <TextBlock x:Name="ConditionText"
                   Text="{Binding Condition}"
                   Visibility="{Binding Type, Converter={StaticResource ConditionToVisibilityConverter}}"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,5,5,0"
                   FontSize="10"
                   FontFamily="Arial"
                   Foreground="#666666"
                   Background="White"
                   Padding="2,1"/>
        
        <!-- 图标占位（矩形节点左侧） -->
        <Border x:Name="IconPlaceholder"
                Width="24" Height="24"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="5,0,0,0"
                Visibility="Collapsed"
                Background="Transparent">
            <Image Source="/Resources/Icons/process.png" 
                   Stretch="Uniform"
                   Visibility="Collapsed"/>
        </Border>
    </Grid>
</UserControl>
