<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:nodify="clr-namespace:Nodify;assembly=Nodify"
                    xmlns:vm="clr-namespace:Flow_Wpf.Nodify.ViewModels">

    <!-- Start Node Template - Rounded Rectangle, Dark Background -->
    <DataTemplate x:Key="StartNodeTemplate" DataType="{x:Type vm:NodeViewModel}">
        <Border Background="#333333" 
                CornerRadius="15" 
                BorderBrush="White" 
                BorderThickness="2"
                Padding="20,15"
                MinWidth="120">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="▶" 
                          FontSize="24" 
                          Foreground="White" 
                          HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Title}" 
                          Foreground="White" 
                          FontWeight="Bold"
                          HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </DataTemplate>

    <!-- Decision Node Template - Diamond Shape, Light Blue -->
    <DataTemplate x:Key="DecisionNodeTemplate" DataType="{x:Type vm:NodeViewModel}">
        <Grid MinWidth="100" MinHeight="80">
            <Border Background="#E3F2FD" 
                    BorderBrush="#1976D2" 
                    BorderThickness="2"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <RotateTransform Angle="45"/>
                </Border.RenderTransform>
            </Border>
            <ContentPresenter Margin="20" 
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}" 
                          Foreground="#1976D2" 
                          FontWeight="Bold"
                          TextAlignment="Center"/>
            </ContentPresenter>
        </Grid>
    </DataTemplate>

    <!-- Process Node Template - Rectangle, White Background -->
    <DataTemplate x:Key="ProcessNodeTemplate" DataType="{x:Type vm:NodeViewModel}">
        <Border Background="White" 
                BorderBrush="#CCCCCC" 
                BorderThickness="2"
                Padding="20,15"
                MinWidth="150">
            <StackPanel>
                <TextBlock Text="⚙" 
                          FontSize="20" 
                          Foreground="#666666" 
                          HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding Title}" 
                          Foreground="#333333" 
                          FontWeight="Bold"
                          Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
    </DataTemplate>

    <!-- Loop Node Template - Rectangle with Badge, Orange -->
    <DataTemplate x:Key="LoopNodeTemplate" DataType="{x:Type vm:NodeViewModel}">
        <Border Background="#FFF3E0" 
                BorderBrush="#F57C00" 
                BorderThickness="2"
                Padding="20,15"
                MinWidth="150">
            <Grid>
                <StackPanel>
                    <TextBlock Text="🔁" 
                              FontSize="20" 
                              Foreground="#F57C00" 
                              HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding Title}" 
                              Foreground="#333333" 
                              FontWeight="Bold"
                              Margin="0,5,0,0"/>
                </StackPanel>
                <Border Background="#F57C00" 
                        CornerRadius="10" 
                        Padding="8,4" 
                        VerticalAlignment="Top" 
                        HorizontalAlignment="Right"
                        Margin="0,-10,-10,0">
                    <TextBlock Text="FOR" 
                              Foreground="White" 
                              FontSize="10" 
                              FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- End Node Template - Rounded Rectangle, Dark Background -->
    <DataTemplate x:Key="EndNodeTemplate" DataType="{x:Type vm:NodeViewModel}">
        <Border Background="#333333" 
                CornerRadius="15" 
                BorderBrush="White" 
                BorderThickness="2"
                Padding="20,15"
                MinWidth="120">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="⏹" 
                          FontSize="24" 
                          Foreground="White" 
                          HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Title}" 
                          Foreground="White" 
                          FontWeight="Bold"
                          HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </DataTemplate>

    <!-- Node Template Selector -->
    <Style TargetType="nodify:NodeContainer">
        <Setter Property="ContentTemplate" Value="{Binding Type, Converter={StaticResource NodeTypeToTemplateConverter}}"/>
    </Style>

</ResourceDictionary>
