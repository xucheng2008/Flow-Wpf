<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Theme Colors -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="TextBrush" Color="#333333"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
    <SolidColorBrush x:Key="GridBrush" Color="#999999"/>
    
    <!-- Node Colors (same as dark theme for consistency) -->
    <SolidColorBrush x:Key="StartNodeBrush" Color="#333333"/>
    <SolidColorBrush x:Key="DecisionNodeBrush" Color="#E3F2FD"/>
    <SolidColorBrush x:Key="ProcessNodeBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="LoopNodeBrush" Color="#FFF3E0"/>
    <SolidColorBrush x:Key="EndNodeBrush" Color="#333333"/>

    <!-- Default Text Style -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <!-- Button Style -->
    <Style x:Key="ToolbarButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#005A9E"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Toolbar Style -->
    <Style x:Key="MainToolbar" TargetType="ToolBar">
        <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="5"/>
    </Style>

    <!-- Grid Background for Editor -->
    <VisualBrush x:Key="LightGridBackground" TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute">
        <VisualBrush.Visual>
            <Grid Background="Transparent">
                <Ellipse Width="1.5" Height="1.5" Fill="#CCCCCC" Margin="9,9,0,0"/>
            </Grid>
        </VisualBrush.Visual>
    </VisualBrush>

</ResourceDictionary>
