<Window x:Class="Flow_Wpf.Nodify.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Flow_Wpf.Nodify"
        xmlns:nodify="clr-namespace:Nodify;assembly=Nodify"
        mc:Ignorable="d"
        Title="Flow-Wpf Nodify Editor" Height="800" Width="1200">
    <Grid>
        <nodify:NodifyEditor x:Name="Editor"
                              PanGesture="Ctrl+Space"
                              ZoomGesture="Ctrl+Wheel"
                              SelectGesture="LeftClick"
                              MoveGesture="RightClick"
                              SnappingEnabled="True"
                              GridSize="20"/>
    </Grid>
</Window>
