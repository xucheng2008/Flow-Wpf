<Window x:Class="Flow_Wpf.Nodify.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Flow_Wpf.Nodify"
        xmlns:nodify="clr-namespace:Nodify;assembly=Nodify"
        xmlns:vm="clr-namespace:Flow_Wpf.Nodify.ViewModels"
        mc:Ignorable="d"
        Title="Flow-Wpf Nodify Editor" Height="800" Width="1200"
        Background="{DynamicResource BackgroundBrush}">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="Views/NodeTemplates.xaml"/>
                <ResourceDictionary Source="Views/ConnectionStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Style="{StaticResource MainToolbar}">
            <Button Content="📄 New" Command="{Binding NewCommand}" Style="{StaticResource ToolbarButton}"/>
            <Button Content="📂 Open" Command="{Binding OpenCommand}" Style="{StaticResource ToolbarButton}"/>
            <Button Content="💾 Save" Command="{Binding SaveCommand}" Style="{StaticResource ToolbarButton}"/>
            <Separator/>
            <Button Content="➕ Add Node" Command="{Binding AddNodeCommand}" Style="{StaticResource ToolbarButton}"/>
            <Button Content="🗑️ Delete" Command="{Binding DeleteNodeCommand}" Style="{StaticResource ToolbarButton}"/>
            <Separator/>
            <Button Content="▶️ Execute" Command="{Binding ExecuteCommand}" Style="{StaticResource ToolbarButton}"/>
            <Button Content="⏸️ Pause" Command="{Binding PauseCommand}" Style="{StaticResource ToolbarButton}"/>
            <Button Content="⏹️ Stop" Command="{Binding StopCommand}" Style="{StaticResource ToolbarButton}"/>
            <Separator/>
            <Button Content="🔍 Zoom In" Command="{Binding ZoomInCommand}" Style="{StaticResource ToolbarButton}"/>
            <Button Content="🔎 Zoom Out" Command="{Binding ZoomOutCommand}" Style="{StaticResource ToolbarButton}"/>
            <Button Content="🔄 Reset" Command="{Binding ResetZoomCommand}" Style="{StaticResource ToolbarButton}"/>
        </ToolBar>

        <!-- Editor Area -->
        <nodify:NodifyEditor x:Name="Editor"
                              Grid.Row="1"
                              ItemsSource="{Binding Nodes}"
                              ConnectionsSource="{Binding Connections}"
                              PanGesture="Ctrl+Space"
                              ZoomGesture="Ctrl+Wheel"
                              SelectGesture="LeftClick"
                              MoveGesture="RightClick"
                              SnappingEnabled="True"
                              GridSize="20"
                              MinZoom="0.1"
                              MaxZoom="5.0"
                              Background="{StaticResource DarkGridBackground}">
            
            <nodify:NodifyEditor.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{Binding Type, Converter={StaticResource NodeTypeToTemplateConverter}}"/>
                </DataTemplate>
            </nodify:NodifyEditor.ItemTemplate>
            
            <nodify:NodifyEditor.ConnectionTemplate>
                <DataTemplate>
                    <nodify:Connection Style="{StaticResource CircuitConnection}"/>
                </DataTemplate>
            </nodify:NodifyEditor.ConnectionTemplate>
            
        </nodify:NodifyEditor>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="{StaticResource PanelBrush}">
            <StatusBarItem>
                <TextBlock Text="{Binding Nodes.Count, StringFormat='Nodes: {0}'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding Connections.Count, StringFormat='Connections: {0}'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="ZoomText" Text="100%"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
