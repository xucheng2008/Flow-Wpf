<Application x:Class="Flow_Wpf.Nodify.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Flow_Wpf.Nodify"
             xmlns:converters="clr-namespace:Flow_Wpf.Nodify.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Views/NodeTemplates.xaml"/>
                <ResourceDictionary Source="Views/ConnectionStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Converters -->
            <converters:NodeTypeToTemplateConverter x:Key="NodeTypeToTemplateConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
